{
  "name": "dilraba-fans",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:pages": "node scripts/build-pages.mjs",
    "validate": "node scripts/validate-content.mjs && node scripts/validate-en-routes.mjs",
    "optimize:images": "node scripts/optimize-images.mjs",
    "generate:en-routes": "node scripts/generate-en-routes.mjs",
    "split:designs": "node scripts/split-design-variants.mjs",
    "sync:stories": "node scripts/sync-stories-from-markdown.mjs",
    "sync:notion": "node scripts/sync-notion-stories.mjs",
    "analyze": "cross-env ANALYZE=true next build",
    "prebuild": "npm run validate && node scripts/optimize-images.mjs && node scripts/sync-stories-from-markdown.mjs",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.24",
    "lucide-react": "^0.554.0",
    "next": "16.2.7",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.10",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "sharp": "^0.35.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
