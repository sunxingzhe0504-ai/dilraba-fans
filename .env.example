# Site URL for RSS, Open Graph, sitemap (no trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# GitHub Pages build — set by CI or scripts/build-pages.mjs
# GITHUB_PAGES=true
# BASE_PATH=/dilraba-fans

# Optional privacy-friendly analytics (leave unset to disable)
# Plausible: https://plausible.io
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=yourdomain.com

# Umami (self-hosted or cloud): both vars required
# NEXT_PUBLIC_UMAMI_SCRIPT_URL=https://analytics.example.com/script.js
# NEXT_PUBLIC_UMAMI_WEBSITE_ID=your-website-id
